# -----------------------------------------------------------------------------
# Aegis AI Environment Configuration Template
# Copy this file to '.env' and fill in your local development credentials.
# DO NOT commit the '.env' file containing active credentials to GitHub.
# -----------------------------------------------------------------------------

# PostgreSQL Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aegis_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_secure_password_here

# Security Settings
# Generate a secure HS256 key (at least 256-bit / 32 bytes)
AEGIS_JWT_SECRET=your_super_secret_jwt_signing_key_at_least_32_bytes_long_here

# AI Engine / Gemini API Settings
# Get a free API key from Google AI Studio: https://aistudio.google.com/
SPRING_AI_GEMINI_API_KEY=your_gemini_api_key_here
