# -----------------------------------------------------------------------------
# Aegis AI Environment Configuration Template
# Copy this file to '.env' and populate with your credentials.
# Never commit real credentials to your repository!
# -----------------------------------------------------------------------------

# Backend Core Options
PORT=8080

# Database Configuration (PostgreSQL + pgvector)
POSTGRES_PORT=5432
POSTGRES_DB=aegis_db
POSTGRES_USER=aegis_admin
POSTGRES_PASSWORD=your_secure_db_password_here

# Security Configuration (JWT auth tokens)
# Generate a secure HS256 key (minimum 256 bits/32 characters)
AEGIS_JWT_SECRET=your_32_character_jwt_secret_key_here
AEGIS_JWT_EXPIRATION_MS=86400000

# AI Provider API Keys
SPRING_AI_GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Local AI Options (Ollama)
OLLAMA_BASE_URL=http://ollama:11434/v1
